prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing changes should remain an explicit approval step in team workflows.",
    match = [
        "git push",
        "git push origin main",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "push", ["--force", "--force-with-lease"]],
    decision = "forbidden",
    justification = "Do not rewrite remote history from Codex; perform force pushes manually after reviewing the branch state.",
    match = [
        "git push --force",
        "git push --force-with-lease origin main",
    ],
    not_match = [
        "git push",
        "git push origin main",
    ],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard local changes from Codex; inspect status and ask the user for an explicit cleanup plan.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD",
    ],
    not_match = [
        "git reset",
        "git status",
    ],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "prompt",
    justification = "Cleaning untracked files can remove local work and should be approved explicitly.",
    match = [
        "git clean -fd",
        "git clean -fdx",
    ],
    not_match = [
        "git status",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "prompt",
    justification = "Creating pull requests should remain an explicit approval step.",
    match = [
        "gh pr create",
        "gh pr create --fill",
    ],
)

prefix_rule(
    pattern = ["python3", "-m", "pip", "install"],
    decision = "prompt",
    justification = "Python dependency installs should be explicit; prefer project-local dependency isolation.",
    match = [
        "python3 -m pip install requests",
        "python3 -m pip install -r requirements.txt",
    ],
    not_match = [
        "python3 -m py_compile app.py",
        "python3 -m pytest",
    ],
)

prefix_rule(
    pattern = ["cdk", "deploy"],
    decision = "prompt",
    justification = "Deploy actions should be reviewed before leaving the sandbox.",
    match = [
        "cdk deploy",
        "cdk deploy MyStack",
    ],
)

prefix_rule(
    pattern = ["cdk", "destroy"],
    decision = "prompt",
    justification = "Infrastructure destroy actions require explicit approval and an impact statement.",
    match = [
        "cdk destroy",
        "cdk destroy MyStack",
    ],
)

prefix_rule(
    pattern = ["terraform", "apply"],
    decision = "prompt",
    justification = "Infrastructure apply commands should be reviewed before leaving the sandbox.",
    match = [
        "terraform apply",
        "terraform apply -auto-approve",
    ],
)

prefix_rule(
    pattern = ["terraform", "destroy"],
    decision = "prompt",
    justification = "Infrastructure destroy actions require explicit approval and an impact statement.",
    match = [
        "terraform destroy",
        "terraform destroy -auto-approve",
    ],
)

prefix_rule(
    pattern = ["sam", "deploy"],
    decision = "prompt",
    justification = "SAM deploys mutate AWS resources and should be reviewed before leaving the sandbox.",
    match = [
        "sam deploy",
        "sam deploy --guided",
    ],
)

prefix_rule(
    pattern = ["sam", "delete"],
    decision = "prompt",
    justification = "SAM delete removes AWS resources and requires explicit approval with an impact statement.",
    match = [
        "sam delete",
        "sam delete --stack-name MyStack",
    ],
)

prefix_rule(
    pattern = ["aws", "cloudformation", "deploy"],
    decision = "prompt",
    justification = "CloudFormation deploys mutate AWS resources and should be reviewed before leaving the sandbox.",
    match = [
        "aws cloudformation deploy",
        "aws cloudformation deploy --template-file template.yaml --stack-name MyStack",
    ],
)

prefix_rule(
    pattern = ["aws", "cloudformation", "delete-stack"],
    decision = "prompt",
    justification = "CloudFormation stack deletion removes AWS resources and requires explicit approval with an impact statement.",
    match = [
        "aws cloudformation delete-stack",
        "aws cloudformation delete-stack --stack-name MyStack",
    ],
)

prefix_rule(
    pattern = ["aws", "s3", "rm"],
    decision = "prompt",
    justification = "S3 object deletion can remove user or production data and should be approved explicitly.",
    match = [
        "aws s3 rm s3://bucket/key",
        "aws s3 rm s3://bucket/prefix --recursive",
    ],
)

prefix_rule(
    pattern = ["aws", "s3", "rb"],
    decision = "prompt",
    justification = "S3 bucket removal can delete storage boundaries and should be approved explicitly.",
    match = [
        "aws s3 rb s3://bucket",
        "aws s3 rb s3://bucket --force",
    ],
)

prefix_rule(
    pattern = ["kubectl", "delete"],
    decision = "prompt",
    justification = "Kubernetes delete commands can remove running resources and should be approved explicitly.",
    match = [
        "kubectl delete pod example",
        "kubectl delete namespace example",
    ],
)

prefix_rule(
    pattern = ["docker", "system", "prune"],
    decision = "prompt",
    justification = "Docker system prune removes local containers, networks, images, and caches and should be approved explicitly.",
    match = [
        "docker system prune",
        "docker system prune --all",
    ],
)
